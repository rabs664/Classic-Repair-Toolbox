<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ts="clr-namespace:Tabs.TabSchematics"
             mc:Ignorable="d"
             x:Class="CRT.SchematicsFullscreenPlaceholder">

	<Grid x:Name="RootGrid">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*" MinWidth="80" />
			<ColumnDefinition Width="4" />
			<ColumnDefinition Width="*" MinWidth="100" />
		</Grid.ColumnDefinitions>

		<Border Grid.Column="0">
			<TextBlock Text="Fullscreen mode active..."
					   HorizontalAlignment="Center"
					   VerticalAlignment="Center"
					   FontSize="14"
					   FontWeight="SemiBold"
					   Foreground="{DynamicResource Main_Fg}" />
		</Border>

		<Border Grid.Column="1"
				Background="{DynamicResource AppThemeBorderBrush}" />

		<ListBox x:Name="SchematicsThumbnailListPlaceholder"
                 Grid.Column="2"
                 Background="Transparent"
                 SelectionMode="Single"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

			<ListBox.Styles>
				<Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
					<Setter Property="Background" Value="Transparent" />
				</Style>
				<Style Selector="ListBoxItem:selected /template/ ContentPresenter">
					<Setter Property="Background" Value="Transparent" />
				</Style>

				<Style Selector="ListBoxItem:pointerover">
					<Setter Property="Cursor" Value="Hand" />
				</Style>

				<Style Selector="ListBoxItem">
					<Setter Property="Padding" Value="0" />
					<Setter Property="HorizontalContentAlignment" Value="Stretch" />
				</Style>

				<Style Selector="ListBoxItem Border.ThumbnailBorder">
					<Setter Property="BorderBrush" Value="{DynamicResource Thumbnail_Border}" />
					<Setter Property="BorderThickness" Value="1" />
				</Style>

				<Style Selector="ListBoxItem:selected Border.ThumbnailBorder">
					<Setter Property="BorderBrush" Value="{DynamicResource Thumbnail_BorderSelected}" />
					<Setter Property="BorderThickness" Value="3" />
				</Style>
			</ListBox.Styles>

			<ListBox.ItemTemplate>
				<DataTemplate x:DataType="ts:SchematicThumbnail">
					<Border Classes="ThumbnailBorder"
                            Margin="4,4,8,4"
                            CornerRadius="0"
                            HorizontalAlignment="Stretch"
                            ClipToBounds="True"
                            Opacity="{Binding VisualOpacity}">
						<Grid>
							<Grid IsVisible="{Binding !IsDropPlaceholder}">
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="*" />
								</Grid.RowDefinitions>

								<Border Grid.Row="0"
										Background="{DynamicResource Thumbnail_Bg}"
										BorderBrush="{DynamicResource Thumbnail_Border}"
										BorderThickness="0,0,0,1">
									<Grid>
										<Border Background="{DynamicResource Thumbnail_Selection_Bg}"
												Opacity="1.0"
												IsVisible="{Binding IsMatchForSelection}" />
										<TextBlock Text="{Binding Name}"
												   Foreground="{DynamicResource Thumbnail_Txt}"
												   HorizontalAlignment="Stretch"
												   TextAlignment="Left"
												   FontSize="11"
												   Padding="4,3"
												   IsVisible="{Binding !IsMatchForSelection}" />
										<TextBlock Text="{Binding Name}"
												   Foreground="{DynamicResource Thumbnail_Selection_Txt}"
												   HorizontalAlignment="Stretch"
												   TextAlignment="Left"
												   FontSize="11"
												   Padding="4,3"
												   IsVisible="{Binding IsMatchForSelection}" />
									</Grid>
								</Border>

								<Grid Grid.Row="1">
									<TextBlock Text="Missing Image"
											   HorizontalAlignment="Center"
											   VerticalAlignment="Center"
											   Foreground="{DynamicResource Main_Fg}"
											   FontSize="11"
											   Padding="8,16"
											   TextAlignment="Center"
											   TextWrapping="Wrap"
											   IsVisible="{Binding ImageSource, Converter={x:Static ObjectConverters.IsNull}}" />

									<Image Source="{Binding ImageSource}"
										   Stretch="Uniform"
										   HorizontalAlignment="Stretch"
										   RenderOptions.BitmapInterpolationMode="HighQuality" />
								</Grid>
							</Grid>
						</Grid>
					</Border>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>
</UserControl>