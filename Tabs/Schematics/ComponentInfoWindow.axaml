<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CRT"
        x:Class="CRT.ComponentInfoWindow"
        Title="Component Information"
        Width="680"
        Height="420"
        MinWidth="420"
        MinHeight="260">

	<Window.Styles>
		<!-- Region toggle buttons -->
		<Style Selector="Button.RegionToggle.active">
			<Setter Property="BorderThickness" Value="2" />
		</Style>

		<!-- PAL active -->
		<Style Selector="Button#PalRegionButton.RegionToggle.active">
			<Setter Property="Foreground" Value="{DynamicResource Schematics_Region_PAL_Fg}" />
			<Setter Property="BorderBrush" Value="{DynamicResource Schematics_Region_PAL_Bg}" />
		</Style>
		<Style Selector="Button#PalRegionButton.RegionToggle.active /template/ ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource Schematics_Region_PAL_Bg}" />
			<Setter Property="BorderBrush" Value="{DynamicResource Schematics_Region_PAL_Bg}" />
		</Style>

		<!-- NTSC active -->
		<Style Selector="Button#NtscRegionButton.RegionToggle.active">
			<Setter Property="Foreground" Value="{DynamicResource Schematics_Region_NTSC_Fg}" />
			<Setter Property="BorderBrush" Value="{DynamicResource Schematics_Region_NTSC_Bg}" />
		</Style>
		<Style Selector="Button#NtscRegionButton.RegionToggle.active /template/ ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource Schematics_Region_NTSC_Bg}" />
			<Setter Property="BorderBrush" Value="{DynamicResource Schematics_Region_NTSC_Bg}" />
		</Style>
	</Window.Styles>

	<Grid x:Name="RootGrid" ColumnDefinitions="*,4,*" Focusable="True">

		<!-- Left panel: top image + horizontal splitter + bottom thumbnail gallery -->
		<Grid x:Name="LeftPanelGrid"
			  Grid.Column="0"
			  Background="Transparent"
			  RowDefinitions="*,4,100">

			<!-- Top: primary component image -->
			<Border x:Name="MainImageClickArea"
					Grid.Row="0"
					ClipToBounds="True"
					Background="Transparent">
				<Grid>
					<TextBlock x:Name="NoImageText"
							   Text="No image available"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Center"
							   FontSize="12"
							   Foreground="{DynamicResource Main_Header_Fg}" />

					<!-- Wrap the Image in a Border to apply the background tightly to the image bounds -->
					<Border x:Name="MainImageContainer"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							Background="{DynamicResource ComponentPopup_ImageTransparent_Bg}"
							CornerRadius="2"
							RenderTransformOrigin="0,0">
						<Border.RenderTransform>
							<MatrixTransform />
						</Border.RenderTransform>
						<Image x:Name="MainComponentImage"
							   Stretch="Uniform" />
					</Border>

					<!-- Top-left info overlay: pin/name, name, oscilloscope reading, region -->
					<StackPanel VerticalAlignment="Top"
								HorizontalAlignment="Left"
								Orientation="Horizontal"
								Margin="6,6,0,0"
								Spacing="4">
						<Border x:Name="InfoPinBorder"
                                Background="{DynamicResource ComponentPopup_OverlayKhaki_Bg}"
                                BorderBrush="{DynamicResource ComponentPopup_OverlayKhaki_Border}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="5,2"
                                IsVisible="False">
							<TextBlock x:Name="InfoPinText"
						               FontSize="11"
						               Foreground="{DynamicResource ComponentPopup_OverlayKhaki_Fg}" />
						</Border>
						<Border x:Name="InfoNameBorder"
								Background="{DynamicResource ComponentPopup_OverlayKhaki_Bg}"
								BorderBrush="{DynamicResource ComponentPopup_OverlayKhaki_Border}"
								BorderThickness="1"
								CornerRadius="2"
								Padding="5,2"
								IsVisible="False">
							<TextBlock x:Name="InfoNameText"
						               FontSize="11"
						               Foreground="{DynamicResource ComponentPopup_OverlayKhaki_Fg}" />
						</Border>
						<Border x:Name="InfoOscBorder"
								Background="{DynamicResource ComponentPopup_OverlayOsc_Bg}"
								BorderBrush="{DynamicResource ComponentPopup_OverlayOsc_Border}"
								BorderThickness="1"
								CornerRadius="2"
								Padding="5,2"
								IsVisible="False">
							<TextBlock x:Name="InfoOscText"
						               FontSize="11"
						               Foreground="{DynamicResource ComponentPopup_OverlayOsc_Fg}" />
						</Border>
						<Border x:Name="InfoRegionBorder"
                                BorderBrush="{DynamicResource AppThemeBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="2"
                                Padding="5,2"
                                IsVisible="False">
							<TextBlock x:Name="InfoRegionText"
                                       FontSize="11" />
						</Border>
					</StackPanel>

					<!-- Bottom-left image counter overlay -->
					<Border x:Name="ImageCounterBorder"
							VerticalAlignment="Bottom"
                            HorizontalAlignment="Left"
                            Margin="6,0,0,6"
							Background="{DynamicResource ComponentPopup_ImageCounter_Bg}"
							BorderBrush="{DynamicResource ComponentPopup_ImageCounter_Border}"
							BorderThickness="1"
                            CornerRadius="2"
                            Padding="5,2"
                            IsVisible="False">
						<TextBlock x:Name="ImageCounterText"
					               FontSize="11"
					               Foreground="{DynamicResource ComponentPopup_ImageCounter_Fg}" />
					</Border>

					<!-- Center: pin jump confirmation flash -->
					<Border x:Name="PinFlashBorder"
							HorizontalAlignment="Center"
                            VerticalAlignment="Center"
							Background="{DynamicResource ComponentPopup_KeyboardTyping_Bg}"
							BorderBrush="{DynamicResource ComponentPopup_Flash_Border}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="20,10"
                            IsHitTestVisible="False"
                            IsVisible="False">
						<TextBlock x:Name="PinFlashText"
						           FontSize="36"
						           FontWeight="Bold"
						           Foreground="{DynamicResource ComponentPopup_KeyboardTyping_Fg}" />
					</Border>
				</Grid>
			</Border>

			<!-- Horizontal splitter -->
			<GridSplitter Grid.Row="1"
                          ResizeDirection="Rows"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource AppThemeBorderBrush}" />

			<!-- Bottom: horizontally scrollable thumbnail gallery -->
			<Border Grid.Row="2"
                    ClipToBounds="True">
				<ListBox x:Name="ThumbnailList"
                         SelectionMode="Single"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">

					<ListBox.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal" />
						</ItemsPanelTemplate>
					</ListBox.ItemsPanel>

					<ListBox.Styles>
						<Style Selector="ListBoxItem">
							<Setter Property="Padding" Value="0" />
							<Setter Property="Margin" Value="0" />
						</Style>
						<Style Selector="ListBoxItem /template/ ContentPresenter">
							<Setter Property="Background" Value="Transparent" />
						</Style>
						<Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
							<Setter Property="Background" Value="Transparent" />
						</Style>
						<Style Selector="ListBoxItem:selected /template/ ContentPresenter">
							<Setter Property="Background" Value="Transparent" />
						</Style>
						<Style Selector="ListBoxItem Border.ThumbnailItemBorder">
							<Setter Property="BorderBrush" Value="LightGray" />
							<Setter Property="BorderThickness" Value="1" />
						</Style>
						<Style Selector="ListBoxItem:selected Border.ThumbnailItemBorder">
							<Setter Property="BorderBrush" Value="{DynamicResource Thumbnail_BorderSelected}" />
							<Setter Property="BorderThickness" Value="3" />
						</Style>
					</ListBox.Styles>

					<ListBox.ItemTemplate>
						<DataTemplate x:DataType="local:ComponentImageItem">
							<Border Classes="ThumbnailItemBorder"
                                    Width="110"
                                    Margin="0"
                                    CornerRadius="2"
                                    Background="{DynamicResource Main_Bg}">

								<!-- Single cell: image + label overlay -->
								<Grid MinHeight="40">
									<TextBlock Text="No image"
                                               IsVisible="{Binding ImageSource, Converter={x:Static ObjectConverters.IsNull}}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="10"
                                               Foreground="{DynamicResource Main_Header_Fg}" />
									<Image Source="{Binding ImageSource}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch" />

									<!-- Label overlay: top-left, a few pixels inside the border -->
									<Border IsVisible="{Binding LabelVisible}"
											VerticalAlignment="Top"
											HorizontalAlignment="Left"
											Margin="3,3,0,0"
											Background="{DynamicResource ComponentPopup_OverlayKhaki_Bg}"
											BorderBrush="{DynamicResource ComponentPopup_OverlayDarkKhaki_Border}"
											BorderThickness="1"
											CornerRadius="2"
											Padding="3,1">
										<TextBlock Text="{Binding Label}"
												   FontSize="9"
												   Foreground="{DynamicResource ComponentPopup_OverlayKhaki_Fg}" />
									</Border>
								</Grid>

							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>

				</ListBox>
			</Border>

		</Grid>

		<!-- Vertical splitter (full height) -->
		<GridSplitter Grid.Column="1"
                      ResizeDirection="Columns"
                      HorizontalAlignment="Stretch"
                      Background="{DynamicResource AppThemeBorderBrush}" />

		<!-- Right panel: component info -->
		<Grid Grid.Column="2"
			  Margin="12"
			  RowDefinitions="Auto,*,Auto">

			<SelectableTextBlock x:Name="TitleText"
					 Grid.Row="0"
					 FontSize="16"
					 FontWeight="SemiBold"
					 Margin="0,0,0,8" />

			<ScrollViewer Grid.Row="1"
						  HorizontalScrollBarVisibility="Disabled"
						  VerticalScrollBarVisibility="Auto">
				<StackPanel Spacing="8">

					<!-- 2. Category | Part-number (hidden when empty) -->
					<SelectableTextBlock x:Name="InfoCategoryPartNumber"
										 TextWrapping="Wrap"
										 FontSize="12"
										 Foreground="{DynamicResource Main_Header_Fg}"
										 IsVisible="False" />

					<!-- 3. Component one-liner (hidden when empty) -->
					<StackPanel x:Name="OneLinerSection"
								IsVisible="False"
								Spacing="4">
						<Border BorderBrush="{DynamicResource AppThemeBorderBrush}"
							BorderThickness="0"
							Padding="0,0,0,3"
							Margin="0,4,0,2">
							<TextBlock Text="Component one-liner"
						   FontSize="10"
						   FontWeight="SemiBold"
						   Foreground="{DynamicResource Main_Header_Fg}" />
						</Border>
						<TextBox x:Name="InfoDescription"
							 IsReadOnly="True"
							 AcceptsReturn="False"
							 TextWrapping="Wrap"
							 FontSize="12" />
					</StackPanel>

					<!-- 4. Image note (hidden when empty or no thumbnail selected) -->
					<StackPanel x:Name="ImageNoteSection"
								IsVisible="False"
								Spacing="4">
						<Border BorderBrush="{DynamicResource AppThemeBorderBrush}"
					BorderThickness="0"
					Padding="0,0,0,3"
					Margin="0,4,0,2">
							<TextBlock Text="Image note"
						   FontSize="10"
						   FontWeight="SemiBold"
						   Foreground="{DynamicResource Main_Header_Fg}" />
						</Border>
						<TextBox x:Name="InfoNote"
					 IsReadOnly="True"
					 AcceptsReturn="False"
					 TextWrapping="Wrap"
					 FontSize="12" />
					</StackPanel>

					<!-- 5. Component local files (hidden when empty) -->
					<StackPanel x:Name="LocalFilesSection"
								IsVisible="False"
								Spacing="4">
						<Border BorderBrush="{DynamicResource AppThemeBorderBrush}"
								BorderThickness="0,0,0,1"
								Padding="0,0,0,4"
								Margin="0,4,0,2">
							<StackPanel Orientation="Horizontal" Spacing="4">
								<TextBlock Text="📁"
										   FontSize="11"
										   VerticalAlignment="Center" />
								<TextBlock Text="Component local files"
										   FontSize="10"
										   FontWeight="SemiBold"
										   Foreground="{DynamicResource Main_Header_Fg}" />
							</StackPanel>
						</Border>
						<ListBox x:Name="LocalFilesList"
								 Background="Transparent"
								 BorderThickness="0"
								 SelectionMode="Single"
								 Padding="0">
							<ListBox.Styles>
								<Style Selector="ListBoxItem">
									<Setter Property="Padding" Value="0" />
									<Setter Property="Margin" Value="0,0,0,3" />
									<Setter Property="Cursor" Value="Hand" />
								</Style>
								<Style Selector="ListBoxItem /template/ ContentPresenter">
									<Setter Property="Background" Value="Transparent" />
									<Setter Property="CornerRadius" Value="4" />
								</Style>
								<Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
									<Setter Property="Background" Value="{DynamicResource List_Selected_Bg}" />
								</Style>
								<Style Selector="ListBoxItem:selected /template/ ContentPresenter">
									<Setter Property="Background" Value="{DynamicResource List_Selected_Bg}" />
								</Style>
							</ListBox.Styles>
							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="local:ComponentLocalFileItem">
									<Grid ColumnDefinitions="26,*" MinHeight="32">
										<TextBlock Grid.Column="0"
												   Text="•"
												   FontSize="14"
												   Foreground="{DynamicResource ComponentPopup_BulletList_Fg}"
												   HorizontalAlignment="Center"
												   VerticalAlignment="Center" />
										<TextBlock Grid.Column="1"
												   Text="{Binding Name}"
												   FontSize="12"
												   Margin="0,0,8,0"
												   VerticalAlignment="Center"
												   Foreground="{DynamicResource Main_Fg}"
												   TextTrimming="CharacterEllipsis" />
									</Grid>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</StackPanel>

					<!-- 6. Component links (hidden when empty) -->
					<StackPanel x:Name="LinksSection"
								IsVisible="False"
								Spacing="4">
						<Border BorderBrush="{DynamicResource AppThemeBorderBrush}"
								BorderThickness="0,0,0,1"
								Padding="0,0,0,4"
								Margin="0,4,0,2">
							<StackPanel Orientation="Horizontal" Spacing="4">
								<TextBlock Text="🔗"
										   FontSize="11"
										   VerticalAlignment="Center" />
								<TextBlock Text="Component links"
										   FontSize="10"
										   FontWeight="SemiBold"
										   Foreground="{DynamicResource Main_Header_Fg}" />
							</StackPanel>
						</Border>
						<ListBox x:Name="LinksList"
								 Background="Transparent"
								 BorderThickness="0"
								 SelectionMode="Single"
								 Padding="0">
							<ListBox.Styles>
								<Style Selector="ListBoxItem">
									<Setter Property="Padding" Value="0" />
									<Setter Property="Margin" Value="0,0,0,3" />
									<Setter Property="Cursor" Value="Hand" />
								</Style>
								<Style Selector="ListBoxItem /template/ ContentPresenter">
									<Setter Property="Background" Value="Transparent" />
									<Setter Property="CornerRadius" Value="4" />
								</Style>
								<Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
									<Setter Property="Background" Value="{DynamicResource List_Selected_Bg}" />
								</Style>
								<Style Selector="ListBoxItem:selected /template/ ContentPresenter">
									<Setter Property="Background" Value="{DynamicResource List_Selected_Bg}" />
								</Style>
							</ListBox.Styles>
							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="local:ComponentLinkItem">
									<Grid ColumnDefinitions="26,*" MinHeight="32">
										<TextBlock Grid.Column="0"
												   Text="•"
												   FontSize="14"
												   Foreground="{DynamicResource ComponentPopup_BulletList_Fg}"
												   HorizontalAlignment="Center"
												   VerticalAlignment="Center" />
										<TextBlock Grid.Column="1"
												   Text="{Binding Name}"
												   FontSize="12"
												   Margin="0,0,8,0"
												   VerticalAlignment="Center"
												   Foreground="{DynamicResource Main_Fg}"
												   TextTrimming="CharacterEllipsis" />
									</Grid>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>
					</StackPanel>

				</StackPanel>
			</ScrollViewer>

			<!-- Region toggle: local PAL / NTSC buttons (does not affect the global region setting) -->
			<Border x:Name="RegionControlsBorder"
					Grid.Row="2"
					BorderBrush="{DynamicResource AppThemeBorderBrush}"
					BorderThickness="0,1,0,0"
					Padding="0,6,0,0"
					Margin="0,6,0,0">
				<Grid ColumnDefinitions="Auto,4,Auto,12,Auto,*,Auto">
					<Button x:Name="PalRegionButton"
					Classes="RegionToggle"
					Grid.Column="0"
					Content="PAL (0)"
					FontSize="11"
					Padding="8,3"
					MinHeight="0"
					Click="OnPalRegionClick" />
					<Button x:Name="NtscRegionButton"
										Classes="RegionToggle"
										Grid.Column="2"
										Content="NTSC (0)"
										FontSize="11"
										Padding="8,3"
										MinHeight="0"
										Click="OnNtscRegionClick" />

					<!-- Scroll action behavior toggle -->
					<ComboBox x:Name="ScrollActionCombo"
							  Grid.Column="4"
							  FontSize="11"
							  Padding="8,3"
							  MinHeight="0"
							  VerticalAlignment="Center">
						<ComboBoxItem FontSize="11">Image change</ComboBoxItem>
						<ComboBoxItem FontSize="11">Image zoom</ComboBoxItem>
					</ComboBox>

					<Button Grid.Column="6"
							Content="Close"
							HorizontalAlignment="Right"
							VerticalAlignment="Center"
							FontSize="12"
							Padding="12,4"
							Margin="12,0,0,0"
							Click="OnCloseButtonClick" />
				</Grid>
			</Border>

		</Grid>

	</Grid>

</Window>