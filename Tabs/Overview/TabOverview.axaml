<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CRT"
             x:Class="CRT.TabOverview"
             FontSize="11">

	<UserControl.Styles>
		<Style Selector="Border.OverviewRow">
			<Setter Property="Background" Value="Transparent" />
		</Style>

		<Style Selector="Border.OverviewRow:pointerover">
			<Setter Property="Background" Value="{DynamicResource Table_RowHover_Bg}" />
		</Style>

		<Style Selector="Button.OverviewTextButton">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderBrush" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="MinHeight" Value="0" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Left" />
			<Setter Property="VerticalContentAlignment" Value="Top" />
		</Style>

		<Style Selector="Button.OverviewTextButton /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>

		<Style Selector="Button.OverviewTextButton:pointerover">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderBrush" Value="Transparent" />
		</Style>

		<Style Selector="Button.OverviewTextButton:pressed">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderBrush" Value="Transparent" />
		</Style>

		<Style Selector="TextBlock.OverviewHeaderText">
			<Setter Property="FontWeight" Value="Bold" />
			<Setter Property="FontSize" Value="12" />
			<Setter Property="Foreground" Value="{DynamicResource Main_Header_Fg}" />
		</Style>
	</UserControl.Styles>

	<Grid>
		<Border BorderBrush="{DynamicResource AppThemeBorderBrush}"
		        BorderThickness="1"
		        CornerRadius="6"
		        ClipToBounds="True"
		        Background="{DynamicResource Table_Bg}">
			<Grid RowDefinitions="Auto,*">

				<Border Grid.Row="0"
						Background="{DynamicResource Table_Bg}"
						Padding="0,12,0,0">
					<Grid Margin="0,0,16,0">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="96" />
							<ColumnDefinition Width="130" />
							<ColumnDefinition Width="150" />
							<ColumnDefinition Width="120" />
							<ColumnDefinition Width="220" />
							<ColumnDefinition Width="*" MinWidth="150" />
							<ColumnDefinition Width="150" />
						</Grid.ColumnDefinitions>

						<Grid Grid.Column="0">
							<Grid RowDefinitions="Auto,Auto">
								<TextBlock Grid.Row="0"
								           Classes="OverviewHeaderText"
								           Text="Component"
								           Margin="8,0,8,0" />
								<Border Grid.Row="1"
								        Height="1"
								        Background="{DynamicResource AppThemeBorderBrush}"
								        Margin="8,4,8,8" />
							</Grid>
						</Grid>

						<Grid Grid.Column="1">
							<Grid RowDefinitions="Auto,Auto">
								<TextBlock Grid.Row="0"
								           Classes="OverviewHeaderText"
								           Text="Technical name"
								           Margin="8,0,8,0" />
								<Border Grid.Row="1"
								        Height="1"
								        Background="{DynamicResource AppThemeBorderBrush}"
								        Margin="8,4,8,8" />
							</Grid>
						</Grid>

						<Grid Grid.Column="2">
							<Grid RowDefinitions="Auto,Auto">
								<TextBlock Grid.Row="0"
								           Classes="OverviewHeaderText"
								           Text="Friendly name"
								           Margin="8,0,8,0" />
								<Border Grid.Row="1"
								        Height="1"
								        Background="{DynamicResource AppThemeBorderBrush}"
								        Margin="8,4,8,8" />
							</Grid>
						</Grid>

						<Grid Grid.Column="3">
							<Grid RowDefinitions="Auto,Auto">
								<TextBlock Grid.Row="0"
								           Classes="OverviewHeaderText"
								           Text="Part-number"
								           Margin="8,0,8,0" />
								<Border Grid.Row="1"
								        Height="1"
								        Background="{DynamicResource AppThemeBorderBrush}"
								        Margin="8,4,8,8" />
							</Grid>
						</Grid>

						<Grid Grid.Column="4">
							<Grid RowDefinitions="Auto,Auto">
								<TextBlock Grid.Row="0"
								           Classes="OverviewHeaderText"
								           Text="Short description"
								           Margin="8,0,8,0" />
								<Border Grid.Row="1"
								        Height="1"
								        Background="{DynamicResource AppThemeBorderBrush}"
								        Margin="8,4,8,8" />
							</Grid>
						</Grid>

						<Grid Grid.Column="5">
							<Grid RowDefinitions="Auto,Auto">
								<TextBlock Grid.Row="0"
								           Classes="OverviewHeaderText"
								           Text="Notes"
								           Margin="8,0,8,0" />
								<Border Grid.Row="1"
								        Height="1"
								        Background="{DynamicResource AppThemeBorderBrush}"
								        Margin="8,4,8,8" />
							</Grid>
						</Grid>

						<Grid Grid.Column="6">
							<Grid RowDefinitions="Auto,Auto">
								<TextBlock Grid.Row="0"
								           Classes="OverviewHeaderText"
								           Text="Files and links"
								           Margin="8,0,8,0" />
								<Border Grid.Row="1"
								        Height="1"
								        Background="{DynamicResource AppThemeBorderBrush}"
								        Margin="8,4,8,8" />
							</Grid>
						</Grid>
					</Grid>
				</Border>

				<ScrollViewer Grid.Row="1"
				              VerticalScrollBarVisibility="Visible"
				              HorizontalScrollBarVisibility="Disabled">
					<ItemsControl x:Name="OverviewItemsControl"
					              Background="{DynamicResource Table_Bg}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="local:OverviewRow">
								<Border Classes="OverviewRow"
								        BorderBrush="{DynamicResource Table_BorderRowLine}"
								        BorderThickness="0,0,0,1"
								        Padding="0,4">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="96" />
											<ColumnDefinition Width="130" />
											<ColumnDefinition Width="150" />
											<ColumnDefinition Width="120" />
											<ColumnDefinition Width="220" />
											<ColumnDefinition Width="*" MinWidth="150" />
											<ColumnDefinition Width="150" />
										</Grid.ColumnDefinitions>

										<Button Grid.Column="0"
											Classes="OverviewTextButton"
											Margin="8,4,8,4"
											VerticalAlignment="Top"
											Cursor="Hand"
											Click="OnComponentClick">
											<TextBlock Text="{Binding Component}"
													   TextDecorations="Underline"
													   Foreground="{DynamicResource AppThemeAccentBrush}" />
										</Button>

										<SelectableTextBlock Grid.Column="1"
										                     Text="{Binding TechnicalName}"
										                     TextWrapping="Wrap"
										                     Margin="8,4,8,4"
										                     VerticalAlignment="Top"
										                     Foreground="{DynamicResource Table_Fg}" />

										<SelectableTextBlock Grid.Column="2"
										                     Text="{Binding FriendlyName}"
										                     TextWrapping="Wrap"
										                     Margin="8,4,8,4"
										                     VerticalAlignment="Top"
										                     Foreground="{DynamicResource Table_Fg}" />

										<SelectableTextBlock Grid.Column="3"
										                     Text="{Binding PartNumber}"
										                     TextWrapping="Wrap"
										                     Margin="8,4,8,4"
										                     VerticalAlignment="Top"
										                     Foreground="{DynamicResource Table_Fg}" />

										<SelectableTextBlock Grid.Column="4"
										                     Text="{Binding ShortDescription}"
										                     TextWrapping="Wrap"
										                     Margin="8,4,8,4"
										                     VerticalAlignment="Top"
										                     Foreground="{DynamicResource Table_Fg}" />

										<SelectableTextBlock Grid.Column="5"
										                     Text="{Binding Notes}"
										                     TextWrapping="Wrap"
										                     Margin="8,4,8,4"
										                     VerticalAlignment="Top"
										                     Foreground="{DynamicResource Table_Fg}" />

										<ItemsControl Grid.Column="6"
										              ItemsSource="{Binding Links}"
										              Margin="8,4,8,4"
										              VerticalAlignment="Top">
											<ItemsControl.ItemTemplate>
												<DataTemplate x:DataType="local:OverviewLink">
													<Button Classes="OverviewTextButton"
													        Margin="0,0,0,2"
													        Cursor="Hand"
													        Click="OnLinkClick">
														<StackPanel Orientation="Horizontal" Spacing="4">
															<TextBlock Text="F:"
															           IsVisible="{Binding IsLocalFile}"
															           Foreground="{DynamicResource Table_Fg}" />
															<TextBlock Text="W:"
															           IsVisible="{Binding IsWebLink}"
															           Foreground="{DynamicResource Table_Fg}" />
															<TextBlock Text="{Binding Name}"
															           TextDecorations="Underline"
															           Foreground="{DynamicResource AppThemeAccentBrush}"
															           TextWrapping="Wrap" />
														</StackPanel>
													</Button>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Grid>
		</Border>
	</Grid>
</UserControl>