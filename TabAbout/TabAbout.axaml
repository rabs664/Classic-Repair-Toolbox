<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CRT"
             x:Class="CRT.TabAbout">

	<UserControl.Styles>
		<!-- Minimal hyperlink button style -->
		<Style Selector="Button.LinkButton">
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Foreground" Value="{DynamicResource AppThemeAccentBrush}" />
			<Setter Property="Padding" Value="8,4" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Cursor" Value="Hand" />
			<Setter Property="HorizontalAlignment" Value="Left" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>

		<Style Selector="Button.LinkButton:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="Button.LinkButton:pointerover TextBlock">
			<Setter Property="Foreground" Value="{DynamicResource AppThemeAccentLightBrush}" />
		</Style>

		<Style Selector="Button.LinkButton:pressed /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent" />
		</Style>

		<Style Selector="Border.ResourceRow">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="Border.ResourceRow:pointerover">
			<Setter Property="Background" Value="{DynamicResource Table_RowHover_Bg}" />
		</Style>
	</UserControl.Styles>

	<ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
		<StackPanel Margin="16">

			<StackPanel Orientation="Horizontal"
                        Spacing="16"
                        VerticalAlignment="Center">

				<Image Source="avares://Classic-Repair-Toolbox/Assets/CRT_icon.png"
                       Width="96"
                       Height="96" />

				<StackPanel VerticalAlignment="Center"
                            Spacing="4">
					<TextBlock x:Name="AboutAssemblyTitleText"
                               FontSize="24"
                               FontWeight="SemiBold" />

					<StackPanel Orientation="Horizontal"
                                Spacing="0">
						<TextBlock Text="Version "
                                   FontSize="14" />
						<TextBlock x:Name="AppVersionText"
                                   FontSize="14"
                                   FontWeight="Bold" />
					</StackPanel>
				</StackPanel>
			</StackPanel>

			<TextBlock Margin="0,16,0,0"
                       VerticalAlignment="Center">
				<Run Text="Orchestrator for this (primarily) vibe-coded application is" />
				<Run Text="Dennis Helligsø" FontWeight="SemiBold" />
			</TextBlock>

			<StackPanel Orientation="Horizontal"
                        Margin="0,16,0,0"
                        Spacing="6">
				<TextBlock Text="GitHub project page:"
                           VerticalAlignment="Center" />
				<Button Content="https://github.com/HovKlan-DH/Classic-Repair-Toolbox"
                        Padding="0"
                        BorderThickness="0"
                        Background="Transparent"
                        Foreground="{DynamicResource AppThemeAccentBrush}"
                        Click="OnGitHubProjectPageClick" />
			</StackPanel>

			<StackPanel Orientation="Horizontal"
            Margin="0,6,0,0"
            Spacing="6">
				<TextBlock Text="Helper page:"
						   VerticalAlignment="Center" />
				<Button Content="https://classic-repair-toolbox.dk"
						Padding="0"
						BorderThickness="0"
						Background="Transparent"
						Foreground="{DynamicResource AppThemeAccentBrush}"
						Click="OnHelperPageClick" />
			</StackPanel>

			<!-- Board revision date section -->
			<StackPanel x:Name="RevisionDatePanel"
						Orientation="Horizontal"
						Spacing="4"
						Margin="0,16,0,0"
						IsVisible="False">
				<TextBlock Text="Board Excel data last revisioned:"
						   FontSize="14" />
				<TextBlock x:Name="RevisionDateText"
						   FontSize="14"
						   FontWeight="Bold" />
			</StackPanel>

			<!-- Credits section — shown only when the loaded board contains credits -->
			<Border x:Name="CreditsSectionBorder"
					IsVisible="False"
					Margin="0,16,0,0">
				<StackPanel Spacing="8">
					<TextBlock Text="Credits specifically for this board:"
							   FontSize="14"
							   Margin="0,0,0,12" />

					<Border BorderBrush="{DynamicResource Table_BorderRowLine}" BorderThickness="1">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto" />
								<RowDefinition Height="*" />
							</Grid.RowDefinitions>

							<!-- Header -->
							<Grid Grid.Row="0" Background="{DynamicResource Table_Header_Bg}">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="220" />
									<ColumnDefinition Width="220" />
									<ColumnDefinition Width="250" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>
								<TextBlock Grid.Column="0" Text="Category" FontWeight="Bold" Padding="8,4" Foreground="{DynamicResource Table_Header_Fg}" />
								<TextBlock Grid.Column="1" Text="Sub-category" FontWeight="Bold" Padding="8,4" Foreground="{DynamicResource Table_Header_Fg}" />
								<TextBlock Grid.Column="2" Text="Author / contributor" FontWeight="Bold" Padding="8,4" Foreground="{DynamicResource Table_Header_Fg}" />
								<TextBlock Grid.Column="3" Text="Contact for author / contributor" FontWeight="Bold" Padding="8,4" Foreground="{DynamicResource Table_Header_Fg}" />
							</Grid>

							<!-- Items -->
							<ItemsControl Grid.Row="1"
										  Background="{DynamicResource Table_Bg}"
										  x:Name="CreditsItemsControl">
								<ItemsControl.ItemTemplate>
									<DataTemplate DataType="local:CreditDisplayItem">
										<Border Classes="ResourceRow" BorderBrush="{DynamicResource Table_BorderRowLine}" BorderThickness="0,0,0,1">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="220" />
													<ColumnDefinition Width="220" />
													<ColumnDefinition Width="250" />
													<ColumnDefinition Width="*" />
												</Grid.ColumnDefinitions>
												<TextBlock Grid.Column="0"
														   Text="{Binding Category}"
														   Foreground="{DynamicResource Table_Fg}"
														   Padding="8,4"
														   VerticalAlignment="Center"
														   TextTrimming="CharacterEllipsis" />
												<TextBlock Grid.Column="1"
														   Text="{Binding SubCategory}"
														   Foreground="{DynamicResource Table_Fg}"
														   Padding="8,4"
														   VerticalAlignment="Center"
														   TextTrimming="CharacterEllipsis" />
												<TextBlock Grid.Column="2"
														   Text="{Binding Name}"
														   Foreground="{DynamicResource Table_Fg}"
														   Padding="8,4"
														   VerticalAlignment="Center"
														   TextTrimming="CharacterEllipsis" />
												<Panel Grid.Column="3" VerticalAlignment="Center" Margin="0,0,8,0">
													<TextBlock Text="{Binding Contact}"
															   Foreground="{DynamicResource Table_Fg}"
															   Padding="8,4"
															   VerticalAlignment="Center"
															   IsVisible="{Binding !IsLink}"
															   TextTrimming="CharacterEllipsis" />
													<Button Classes="LinkButton"
															Command="{Binding OpenContactCommand}"
															IsVisible="{Binding IsLink}">
														<TextBlock Text="{Binding Contact}" TextDecorations="Underline" TextTrimming="CharacterEllipsis" />
													</Button>
												</Panel>
											</Grid>
										</Border>
									</DataTemplate>
								</ItemsControl.ItemTemplate>
							</ItemsControl>
						</Grid>
					</Border>
				</StackPanel>
			</Border>

			<TextBlock Margin="0,16,0,0"
					   TextWrapping="Wrap"
                       Text="Credits will in many cases not be fully represented, but the idea is that at least the main author or contributor should be listed. If more than one person, then the one with the most contribution is placed on top, though this also probably sometimes can be quite hard figuring out exactly. Small contributions are not listed, and the amount contributed for a place here should be &quot;substantial&quot;."
					   Foreground="{DynamicResource Main_Header_Fg}"
					   />
			
		</StackPanel>
	</ScrollViewer>
</UserControl>